<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Signup</title>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #667eea, #764ba2);
      }

      .container {
        background: #fff;
        padding: 30px 25px;
        border-radius: 12px;
        width: 340px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        text-align: center;
      }

      h1 {
        margin-bottom: 20px;
        color: #333;
      }

      form {
        display: flex;
        flex-direction: column;
        text-align: left;
      }

      label {
        margin-bottom: 5px;
        font-size: 14px;
        color: #555;
      }

      input {
        padding: 10px;
        margin-bottom: 15px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 14px;
        transition: 0.2s;
      }

      input:focus {
        border-color: #667eea;
        outline: none;
        box-shadow: 0 0 5px rgba(102, 126, 234, 0.5);
      }

      button {
        padding: 10px;
        border: none;
        border-radius: 6px;
        background: #48bb78;
        color: white;
        font-size: 15px;
        cursor: pointer;
        transition: 0.3s;
      }

      button:hover {
        background: #38a169;
      }

      .login-section {
        margin-top: 15px;
        font-size: 14px;
        color: #555;
      }

      .login-btn {
        margin-top: 8px;
        display: inline-block;
        padding: 8px 12px;
        background: #667eea;
        color: white;
        border-radius: 6px;
        text-decoration: none;
        transition: 0.3s;
      }

      .login-btn:hover {
        background: #5a67d8;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <h1>Signup</h1>
      <% if (locals.error) { %>
      <p style="color: #e53e3e; margin-bottom: 15px; font-size: 14px"><%= error %></p>
      <% } %>

      <form action="/user" method="post">
        <label>Full Name</label>
        <input type="text" required name="name" />

        <label>Email</label>
        <input type="text" required name="email" />

        <label>Password</label>
        <input type="password" required name="password" />

        <button type="submit">Signup</button>
      </form>

      <div class="login-section">
        <p>Already have an account?</p>
        <a href="/login" class="login-btn">Login</a>
      </div>
    </div>
  </body>
</html>
