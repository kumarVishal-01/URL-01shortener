
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100%;
            overflow-x: hidden; /* prevents horizontal scroll */
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #667eea, #764ba2);
        }

        body {
            display: flex;
            justify-content: center;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 900px;
            background: #fff;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        h1 {
            margin: 0;
        }

        .logout-btn {
            padding: 8px 16px;
            background: #ff4d4d;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            font-size: 14px;
            transition: background 0.3s;
        }

        .logout-btn:hover {
            background: #cc0000;
        }

        .result {
            background: #f0f4ff;
            padding: 10px;
            border-radius: 8px;
            margin-bottom: 20px;
            text-align: center;
            word-break: break-all; /* prevents overflow */
        }

        form {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            width: 100%;
        }

        input {
            flex: 1;
            min-width: 0; /* critical to prevent overflow */
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
        }

        button {
            padding: 12px 16px;
            border: none;
            border-radius: 8px;
            background: #667eea;
            color: white;
            cursor: pointer;
            white-space: nowrap;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed; /* prevents expansion */
        }

        th, td {
            padding: 10px;
            text-align: center;
            word-wrap: break-word;
            word-break: break-all; /* key for long URLs */
        }

        thead {
            background: #667eea;
            color: white;
        }

        tbody tr {
            border-bottom: 1px solid #eee;
        }

        tbody tr:hover {
            background: #f5f7ff;
        }

        a {
            color: #667eea;
            text-decoration: none;
            word-break: break-all;
        }

        @media (max-width: 600px) {
            form {
                flex-direction: column;
            }

            button {
                width: 100%;
            }
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <h1>URL Shortener</h1>
            <a href="/user/logout" class="logout-btn">Logout</a>
        </div>

        <% if(locals.id){ %>
<div class="result">
    <a href="https://url-01shortener.onrender.com/<%= id %>" target="_blank">
        https://url-01shortener.onrender.com/<%= id %>
    </a>
</div>
<% } %>

        <form method="post" action="/url">
            <input 
                type="text" 
                name="url" 
                placeholder="https://example.com"
                required
            />
            <button type="submit">Generate</button>
        </form>

        <% if (locals.urls) { %>
        <table>
            <thead>
                <tr>
                    <th>#</th>   
                    <th>Short ID</th>   
                    <th>Original URL</th>   
                    <th>Clicks</th>  
                     <th>User Agent</th> 
                </tr>
            </thead>

          <tbody>
    <% urls.forEach((url, index) => { %>
    <tr>
        <td><%= index + 1 %></td>

        <td>
            <a href="/<%= url.shortId %>" target="_blank">
                <%= url.shortId %>
            </a>
        </td>

        <td>
            <a href="<%= url.redirectURL %>" target="_blank">
                <%= url.redirectURL %>
            </a>
        </td>

        <td><%= url.visitHistory.length %></td>

        <td style="font-size:12px;">
            <% if (url.visitHistory.length) { 
                const ua = url.visitHistory[url.visitHistory.length - 1].userAgent;
            %>
                <span title="<%= ua %>">
                    <%= ua ? ua.slice(0, 50) + "..." : "N/A" %>
                </span>
            <% } else { %>
                N/A
            <% } %>
        </td>
    </tr>
    <% }) %>
</tbody> 
        </table>
        <% } %>
    </div>
</body>
</html>